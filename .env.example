
# ============================================================
# FortniteFrame v1.0.0 — Environment Variables Reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# ---- Fortnite API ----
# Get your API key from https://replayinfo.com
FORTNITE_API_KEY=

# ---- Next.js Public ----
# RPC endpoint for Base (public node, no key required for dev)
NEXT_PUBLIC_RPC_URL=https://base-sepolia.publicnode.com
# Deployed FortniteFrameBadge contract address (set after deploy)
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# API URL (defaults to /api on the same origin)
NEXT_PUBLIC_API_URL=https://demo.castquest.app/api
NEXT_PUBLIC_ENV=demo

# ---- Authentication ----
# Secret for signing JWT access tokens (min 32 random chars)
JWT_SECRET=change-me-to-a-long-random-secret-in-production
# Initial admin password — change before deploying to production
ADMIN_PASSWORD=admin123

# ---- Database (optional in dev, required in production) ----
# PostgreSQL connection string for production
DATABASE_URL=postgresql://user:password@localhost:5432/fortniteframe

# ---- Smart Contract Deployment ----
# Wallet private key (NEVER share or commit)
PRIVATE_KEY=
# Address of the backend signer that authorizes mints
AUTHORIZED_RELAYER=
# Reserve wallet for platform fees
RESERVE_WALLET=

# ---- Base Network RPC ----
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ---- Contract Verification ----
BASESCAN_API_KEY=

