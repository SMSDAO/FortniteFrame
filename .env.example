# ===========================================
# FortniteFrame Environment Configuration
# ===========================================
#
# For local development:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
#
# For Vercel deployment:
# 1. Go to Project Settings > Environment Variables
# 2. Add the required variables marked with [REQUIRED]
# 3. Optional variables can be added as needed
#
# ===========================================

# ===========================================
# REQUIRED: API Keys
# ===========================================

# Fortnite API Key [REQUIRED for production]
# Get your API key from https://replayinfo.com
FORTNITE_API_KEY=your-api-key-here

# ===========================================
# Frontend Configuration (Public Variables)
# ===========================================

# Smart Contract Address [OPTIONAL]
# Set this after deploying FortniteFrameBadge.sol to Base
# Leave as placeholder for frontend-only testing
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# Deployment & Monitoring [OPTIONAL]
# ===========================================

# Deployment URL for health monitoring
# For Vercel: https://your-app.vercel.app
# For local: http://localhost:3000
DEPLOYMENT_URL=http://localhost:3000

# ===========================================
# Smart Contract Deployment [OPTIONAL]
# Only needed if deploying contracts to Base
# ===========================================

# Private key for deploying contracts
# WARNING: NEVER commit this to version control!
# Keep this secret and secure
PRIVATE_KEY=your-private-key-here

# Base RPC URLs (defaults provided)
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Basescan API key for contract verification
BASESCAN_API_KEY=your-basescan-api-key

# Reserve wallet that receives platform fees
# Default: gxqstudio.eth
RESERVE_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

# Platform fee in basis points (250 = 2.5%)
PLATFORM_FEE_BPS=250

# Authorized relayer address for backend signatures
AUTHORIZED_RELAYER=your-relayer-address-here
