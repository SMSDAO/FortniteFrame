# ===========================================
# FortniteFrame Environment Configuration
# Production-Grade Configuration
# ===========================================
#
# This configuration supports:
# - Local development
# - Admin.exe (Tauri) runtime
# - Vercel frontend deployment
# - Automated builds without manual steps
#
# For local development:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values
#
# For Vercel deployment:
# 1. Go to Project Settings > Environment Variables
# 2. Add the required variables marked with [REQUIRED]
# 3. Optional variables can be added as needed
#
# For Admin.exe (Tauri):
# 1. All values are read from .env or .env.local
# 2. No hardcoded secrets or URLs
# 3. Builds succeed using only .env values
# 4. Syncs with Vercel frontend config
#
# Node Version: 24+ required
# ===========================================

# ===========================================
# REQUIRED: API Keys
# ===========================================

# Fortnite API Key [REQUIRED for production]
# Get your API key from https://replayinfo.com
# Used by: Frontend, Admin.exe
FORTNITE_API_KEY=your-api-key-here

# ===========================================
# Frontend Configuration (Public Variables)
# Shared between Frontend and Admin.exe
# ===========================================

# Smart Contract Address [OPTIONAL]
# Set this after deploying FortniteFrameBadge.sol to Base
# Leave as placeholder for frontend-only testing
# Used by: Frontend, Admin.exe
NEXT_PUBLIC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ===========================================
# Deployment & Monitoring [OPTIONAL]
# ===========================================

# Deployment URL for health monitoring
# For Vercel: https://your-app.vercel.app
# For local: http://localhost:3000
# Used by: Frontend, Admin.exe health checks
DEPLOYMENT_URL=http://localhost:3000

# ===========================================
# Smart Contract Deployment [OPTIONAL]
# Only needed if deploying contracts to Base
# Used by: Admin.exe for contract deployment
# ===========================================

# Private key for deploying contracts
# WARNING: NEVER commit this to version control!
# Keep this secret and secure
# Used by: Admin.exe for contract deployment only
PRIVATE_KEY=your-private-key-here

# ===========================================
# Production-Grade Public RPC URLs
# Shared between Frontend and Admin.exe
# ===========================================

# Base Mainnet - Public RPC Endpoints (Production-Grade)
# Primary: Coinbase official public endpoint
# Used by: Frontend, Admin.exe
BASE_RPC_URL=https://mainnet.base.org
# Alternatives (fallback options):
# BASE_RPC_URL=https://base.gateway.tenderly.co
# BASE_RPC_URL=https://base-rpc.publicnode.com

# Base Sepolia Testnet - Public RPC Endpoint
# Used by: Frontend, Admin.exe
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Alternatives (fallback options):
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.gateway.tenderly.co
# BASE_SEPOLIA_RPC_URL=https://base-sepolia-rpc.publicnode.com

# ===========================================
# Contract Verification & Configuration
# Used by: Admin.exe for contract verification
# ===========================================

# Basescan API key for contract verification
# Get from: https://basescan.org/myapikey
# Used by: Admin.exe
BASESCAN_API_KEY=your-basescan-api-key

# Reserve wallet that receives platform fees
# Default: gxqstudio.eth (verified ENS address)
# Used by: Smart contracts, Admin.exe
RESERVE_WALLET=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb

# Platform fee in basis points (250 = 2.5%)
# Used by: Smart contracts, Admin.exe
PLATFORM_FEE_BPS=250

# Authorized relayer address for backend signatures
# This address signs minting approvals
# Used by: Frontend, Admin.exe
AUTHORIZED_RELAYER=your-relayer-address-here

# ===========================================
# Admin.exe Configuration Sync
# ===========================================

# Backend API URL (for config updates)
# Admin.exe uses this to push config updates
# Frontend uses this to fetch runtime config
# For local: http://localhost:3001/api
# For production: https://your-api.example.com/api
ADMIN_API_URL=http://localhost:3001/api

# Database connection for Admin.exe
# Admin.exe uses this to sync config to backend
# Options: Supabase, Neon, or any PostgreSQL-compatible DB
# Example: postgresql://user:password@host:5432/database
DATABASE_URL=your-database-url-here
