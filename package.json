{
  "name": "fortnite-frame",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "heal": "tsx src/scripts/auto-heal.ts",
    "compile": "hardhat compile",
    "deploy:base": "hardhat run scripts/deploy.js --network base",
